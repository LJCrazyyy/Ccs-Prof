{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "education-management-backend",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "node src/server.js",
        "dev:emulator": "firebase emulators:exec --only firestore,auth --import ./data/emulator --export-on-exit ./data/emulator \"node src/server.js\"",
        "emulator:start": "firebase emulators:start --only firestore,auth --import ./data/emulator --export-on-exit ./data/emulator",
        "emulator:seed:all": "firebase emulators:exec --only firestore,auth --import ./data/emulator --export-on-exit ./data/emulator \"node scripts/seed-and-generate-users.mjs\"",
        "emulator:create-prof": "firebase emulators:exec --only firestore,auth --import ./data/emulator --export-on-exit ./data/emulator \"node scripts/create-prof-account.mjs\"",
        "seed:create-prof": "node scripts/create-prof-account.mjs",
        "build": "npm install && vite build",
        "start": "node src/server.js",
        "seed:test-students": "node scripts/generate-test-student-data.mjs",
        "seed:faculty": "node scripts/generate-test-faculty-data.mjs",
        "seed:quicklogin-accounts": "node scripts/create-quicklogin-accounts.mjs",
        "seed:test-data": "node scripts/seed-test-data.mjs",
        "seed:curriculum": "node scripts/seed-all-curriculum.mjs",
        "seed:quicklogin": "node scripts/seed-quicklogin-data.mjs",
        "seed:quicklogin-curriculum": "node scripts/seed-quicklogin-curriculum.mjs"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^17.2.1",
        "education-management-backend": "file:",
        "express": "^5.1.0",
        "firebase-admin": "^13.0.2"
    },
    "devDependencies": {
        "firebase-tools": "^15.15.0"
    }
}
