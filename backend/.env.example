# Backend Firestore config.
# Use this file as a template for backend/.env locally or Render environment variables in production.

# Optional switch for local emulator usage.
# Emulator mode is also auto-enabled if FIRESTORE_EMULATOR_HOST is present.
FIREBASE_USE_EMULATOR=true

# Allowed frontend origins for the API, comma-separated.
# Use your Netlify site URL here in production.
CORS_ORIGIN=http://localhost:5173

# Firebase project id.
FIREBASE_PROJECT_ID=cscs-9ec17

# Service account values required when connecting to production Firestore.
# Leave empty locally if you are using the emulator.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional Firebase services used by the backend.
FIREBASE_DATABASE_URL=https://cscs-9ec17-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_STORAGE_BUCKET=cscs-9ec17.firebasestorage.app

# Firestore emulator host for local development.
FIRESTORE_EMULATOR_HOST=127.0.0.1:8081

# Firebase Auth emulator host for local auth user creation/login.
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
